# Database (Railway auto-provisions this)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/now_schema_explorer?schema=public"

# Auth.js (NextAuth v5) — GitHub OAuth
AUTH_SECRET="generate-a-random-secret-here"
AUTH_GITHUB_ID="your-github-oauth-app-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-client-secret"

# Admin — your numeric GitHub user ID (curl https://api.github.com/users/YOUR_USERNAME → id)
ADMIN_GITHUB_ID="12345678"
